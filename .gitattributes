# 預設使用 LF，避免不同 OS 上行尾不一致
* text=auto eol=lf

# Windows 批次檔必須 CRLF 才能在 Windows 上執行
*.bat text eol=crlf
*.cmd text eol=crlf

# Unix 腳本固定 LF
*.sh text eol=lf
gradlew text eol=lf
gradlew.bat text eol=crlf

# 二進位檔案不做轉換
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.apk binary
*.jar binary
*.keystore binary
*.jks binary
